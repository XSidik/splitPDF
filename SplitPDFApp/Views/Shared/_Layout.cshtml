<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SplitPDFApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style type="text/tailwindcss">
        @@layer base {
            body { @@apply bg-slate-50 text-slate-900; }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
            <a class="text-xl font-bold text-indigo-600" asp-area="" asp-controller="Home" asp-action="Index">SplitPDF</a>
            <div class="hidden sm:flex space-x-8">
                <a class="text-slate-600 hover:text-slate-900" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="text-slate-600 hover:text-slate-900" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>
    <main role="main" class="flex-grow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-white border-t border-slate-200 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-slate-500 text-sm">
            &copy; 2026 - SplitPDFApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
